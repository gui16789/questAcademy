  "misconceptions": [
    {
      "misconceptionId": "mis.average-sharing.unequal-as-equal",
      "knowledgePointId": "math.division.average-sharing",
      "skillId": "skill.average-sharing.identify-equal-groups",
      "name": "把分完误认为平均分",
      "description": "孩子只关注物品是否分完，没有检查每份数量是否一样多。",
      "diagnosisHint": "让孩子逐份比较数量，确认每份相同才是平均分。",
      "remediationStrategyId": "review-average-sharing-basic"
    },
    {
      "misconceptionId": "mis.average-sharing.wrong-share-count",
      "knowledgePointId": "math.division.average-sharing",
      "skillId": "skill.average-sharing.calculate-each-share",
      "name": "把份数和每份数混淆",
      "description": "孩子把要分成几份和每份是多少混在一起。",
      "diagnosisHint": "引导孩子先找总数和份数，再计算每份数量。",
      "remediationStrategyId": "review-average-sharing-basic"
    },
    {
      "misconceptionId": "mis.expression.use-addition",
      "knowledgePointId": "math.division.expression",
      "skillId": "skill.expression.map-story-to-expression",
      "name": "把平均分情境写成加法",
      "description": "孩子没有把平均分识别为除法情境。",
      "diagnosisHint": "检查题干中是否出现平均分、每份、每组等除法线索。",
      "remediationStrategyId": "review-division-expression-basic"
    },
    {
      "misconceptionId": "mis.expression.reverse-roles",
      "knowledgePointId": "math.division.expression",
      "skillId": "skill.expression.explain-quotient",
      "name": "被除数、除数、商含义混淆",
      "description": "孩子不能稳定说清总数、份数或每份数量与算式位置的关系。",
      "diagnosisHint": "让孩子用一句话说明算式中每个数字代表什么。",
      "remediationStrategyId": "review-division-expression-basic"
    },
    {
      "misconceptionId": "mis.remainder.forget-leftover",
      "knowledgePointId": "math.division.with-remainder",
      "skillId": "skill.remainder.calculate",
      "name": "忘记写余数",
      "description": "孩子只写完整分组数量，忽略剩下不够再分一组的数量。",
      "diagnosisHint": "检查完整分组后还剩几个，并把剩余数量写成余数。",
      "remediationStrategyId": "review-with-remainder-basic"
    },
    {
      "misconceptionId": "mis.remainder.leftover-as-group",
      "knowledgePointId": "math.division.with-remainder",
      "skillId": "skill.remainder.explain-leftover",
      "name": "把剩余误当完整一组",
      "description": "孩子把剩下的数量也当成一个完整小组。",
      "diagnosisHint": "比较剩余数量和每组需要的数量，判断是否够再组成完整一组。",
      "remediationStrategyId": "review-with-remainder-basic"
    },
    {
      "misconceptionId": "mis.remainder.greater-than-divisor",
      "knowledgePointId": "math.division.remainder-rule",
      "skillId": "skill.remainder.compare-with-divisor",
      "name": "认为余数可以大于除数",
      "description": "孩子没有意识到余数大于除数时还能继续再分一组。",
      "diagnosisHint": "检查孩子是否理解余数表示剩下不够再分一组的数量。",
      "remediationStrategyId": "review-remainder-rule-basic"
    },
    {
      "misconceptionId": "mis.remainder.equal-divisor",
      "knowledgePointId": "math.division.remainder-rule",
      "skillId": "skill.remainder.compare-with-divisor",
      "name": "认为余数可以等于除数",
      "description": "孩子没有意识到余数等于除数时也能再分一组。",
      "diagnosisHint": "让孩子比较余数和除数，说明相等时为什么还能继续分。",
      "remediationStrategyId": "review-remainder-rule-basic"
    },
    {
      "misconceptionId": "mis.word-problem.use-remainder-wrong",
      "knowledgePointId": "math.division.word-problem",
      "skillId": "skill.word-problem.interpret-remainder",
      "name": "不理解剩余是否能再组成一组",
      "description": "孩子不能把余数放回情境中判断它是否能组成完整小组。",
      "diagnosisHint": "引导孩子对照每组需要数量，判断剩余是否足够。",
      "remediationStrategyId": "review-remainder-rule-basic"
    }
  ],
